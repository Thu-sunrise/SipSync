# ==============================================================================
# 1. SECRETS & ENVIRONMENT VARIABLES (Bảo mật - Tuyệt đối không đẩy lên Git)
# ==============================================================================
.env
.env.*
**/.env
**/secret.yaml
!.env.example

# ==============================================================================
# 2. INFRASTRUCTURE & CLOUD (Hạ tầng - Terraform)
# ==============================================================================
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.kiro/

# ==============================================================================
# 3. DEPENDENCIES (Thư viện tải về)
# ==============================================================================
node_modules/
jspm_packages/
web_modules/
.npm/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ==============================================================================
# 4. BUILD OUTPUT (Các thư mục sinh ra sau khi Build Code)
# ==============================================================================
dist/
build/
out/
.next/
.cache/
.parcel-cache/
*.tsbuildinfo
*.tgz

# ==============================================================================
# 5. LOGS & RUNTIME (Nhật ký chạy ứng dụng)
# ==============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock
.eslintcache
.stylelintcache
.node_repl_history
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
vite.config.js.timestamp-*
